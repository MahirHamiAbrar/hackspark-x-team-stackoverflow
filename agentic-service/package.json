{
  "name": "agentic-service",
  "module": "src/index.ts",
  "scripts": {
    "dev":   "bun --env-file=../.env --watch src/index.ts",
    "start": "bun --env-file=../.env src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^4.17.21"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
